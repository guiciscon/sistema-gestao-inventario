generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Products { 
  id             String   @id @default(uuid())
  name           String
  description    String
  price          Decimal
  stock_quantity Int
  created_at     DateTime @default(now())
  last_update    DateTime @default(now())@updatedAt
}